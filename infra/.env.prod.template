# ============================================
# Production Environment Variables
# Copy to .env.prod on server, fill secrets
# ============================================

# --- Docker / GHCR ---
TAG=latest
GHCR_OWNER=Artiffusion-Inc

# --- Database ---
POSTGRES_DB=skating
POSTGRES_USER=skating
POSTGRES_PASSWORD=change-me-32-chars-min
DATABASE_URL=postgresql+asyncpg://skating:change-me-32-chars-min@postgres:5432/skating

# --- Valkey (Task Queue) ---
VALKEY_URL=redis://valkey:6379/0

# --- Cloudflare R2 (Storage) ---
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=<access-key>
R2_SECRET_KEY=<secret-key>
R2_BUCKET=skating-videos

# --- Auth ---
JWT_SECRET=change-me-64-chars-min-hex-or-random-string

# --- Vast.ai (Remote GPU) ---
# Leave empty to disable remote GPU (fallback local)
VASTAI_API_KEY=

# --- Logging ---
LOG_LEVEL=info

# --- Frontend ---
NEXT_PUBLIC_API_URL=/api

# --- Domain / TLS ---
DOMAIN=bbank.pro
CLOUDFLARE_API_TOKEN=change-me-cloudflare-api-token-with-dns-edit-zone-read
