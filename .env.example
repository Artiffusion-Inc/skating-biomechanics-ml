# Valkey / Redis queue
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_DB=0

# PostgreSQL
POSTGRES_DB=src
POSTGRES_USER=skatelab
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://skatelab:${POSTGRES_PASSWORD}@localhost:5432/src

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Cloudflare R2 (S3-compatible object storage)
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=skatelab-pipeline
CF_R2_ENDPOINT_URL=

# Vast.ai Serverless GPU
VASTAI_API_KEY=
VASTAI_ENDPOINT_NAME=skatelab-worker

# Resend email service
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@skatelab.ru
RESEND_FROM_NAME=SkateLab
RESEND_RESET_URL_TEMPLATE=https://skatelab.ru/reset-password?token={token}
RESEND_VERIFY_URL_TEMPLATE=https://skatelab.ru/verify-email?token={token}
RESEND_DASHBOARD_URL=https://skatelab.ru/dashboard

# General
APP_WORKER_MAX_JOBS=1
APP_LOG_LEVEL=INFO
APP_TASK_TTL_SECONDS=86400

# Dev mode
