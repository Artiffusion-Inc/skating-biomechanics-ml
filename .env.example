# Valkey / Redis queue
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_DB=0

# PostgreSQL
POSTGRES_DB=src
POSTGRES_USER=skatelab
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://skatelab:${POSTGRES_PASSWORD}@localhost:5432/src

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Cloudflare R2 (S3-compatible object storage)
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=skatelab-pipeline
CF_R2_ENDPOINT_URL=

# Vast.ai Serverless GPU
VASTAI_API_KEY=
VASTAI_ENDPOINT_NAME=skatelab-worker

# General
APP_WORKER_MAX_JOBS=1
APP_LOG_LEVEL=INFO
APP_TASK_TTL_SECONDS=86400

# Dev mode — skip auth entirely, use mock user
# APP_SKIP_AUTH=true
# NEXT_PUBLIC_SKIP_AUTH=true
